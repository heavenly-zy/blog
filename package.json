{
	"name": "astro-blog",
	"type": "module",
	"version": "0.0.1",
	"engines": {
		"node": ">=22.12.0"
	},
	"packageManager": "bun@1.3.13",
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"check": "biome check",
		"check:fix": "biome check --write",
		"sync-ai-rules": "node scripts/sync-ai-rules.mjs",
		"postinstall": "lefthook install && node scripts/sync-ai-rules.mjs",
		"preinstall": "bunx only-allow bun"
	},
	"dependencies": {
		"astro": "^6.3.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"lefthook": "^2.1.6"
	},
	"trustedDependencies": [
		"lefthook"
	],
	"imports": {
		"#*": "./src/*"
	}
}
